# Copy to .env and adjust. Never commit .env.

# JSON-RPC (local Hardhat node)
RPC_URL=http://127.0.0.1:8545

# Oracle signer — must be the Hardhat node account that deployed EnergyTrading
# (Account #0 from `npx hardhat node` — same key Hardhat prints at startup)
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# After `npm run deploy:local`, paste the printed address here — it MUST match the
# contract on the node your API uses. If you restart `npm run node` with a wiped chain,
# or deploy again (higher nonce), the address changes: redeploy and update this line.
# Symptoms of a wrong address: API fails at startup ("No contract bytecode") or txs revert.
CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3

# Must match Hardhat network (local default)
CHAIN_ID=31337
